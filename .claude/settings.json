{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "_source": "metaclaude",
            "_id": "workflow-gate-enforcement",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/workflow-gate-enforcement.mjs"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "_source": "metaclaude",
            "_id": "workflow-file-protection",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/workflow-file-protection.mjs"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "_source": "metaclaude",
            "_id": "workflow-file-protection-bash",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/workflow-file-protection.mjs"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "_source": "metaclaude",
            "_id": "e2e-blackbox-enforcement-agent",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/e2e-blackbox-enforcement.mjs"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "_source": "metaclaude",
            "_id": "e2e-blackbox-enforcement-read",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/e2e-blackbox-enforcement.mjs"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "_source": "metaclaude",
            "_id": "e2e-blackbox-enforcement-write",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/e2e-blackbox-enforcement.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "_source": "metaclaude",
            "_id": "json-validate",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/hook-wrapper.mjs '*.json' 'node -e \"const f = process.argv[1]; if (!f.includes('\\''tsconfig'\\'')) JSON.parse(require('\\''fs'\\'').readFileSync(f))\" {{file}}'"
          },
          {
            "_source": "metaclaude",
            "_id": "convergence-field-validate",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/hook-wrapper.mjs '.claude/specs/groups/**/manifest.json' 'node .claude/scripts/validate-convergence-fields.mjs {{file}}'"
          },
          {
            "_source": "metaclaude",
            "_id": "template-validate",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/hook-wrapper.mjs '.claude/templates/*' 'node .claude/scripts/template-validate.mjs {{file}}'"
          },
          {
            "_source": "metaclaude",
            "_id": "agent-frontmatter-validate",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/hook-wrapper.mjs '.claude/agents/*.md' 'node .claude/scripts/validate-agent-frontmatter.mjs {{file}}'"
          },
          {
            "_source": "metaclaude",
            "_id": "skill-frontmatter-validate",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/hook-wrapper.mjs '.claude/skills/*/SKILL.md' 'node .claude/scripts/validate-skill-frontmatter.mjs {{file}}'"
          },
          {
            "_source": "metaclaude",
            "_id": "spec-schema-validate",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/hook-wrapper.mjs '.claude/specs/groups/**/*.md' 'node .claude/scripts/spec-schema-validate.mjs {{file}}'"
          },
          {
            "_source": "metaclaude",
            "_id": "spec-validate",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/hook-wrapper.mjs '.claude/specs/groups/**/*.md' 'node .claude/scripts/spec-validate.mjs {{file}}'"
          },
          {
            "_source": "metaclaude",
            "_id": "structured-docs-validate",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/hook-wrapper.mjs '.claude/docs/**/*.yaml' 'node .claude/scripts/docs-validate.mjs --hook'"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "_source": "metaclaude",
            "_id": "dispatch-record-hook",
            "_comment": "sg-enforcement-layer-gaps Task 23/24/32. Records Task-tool dispatches via session-checkpoint.mjs (sole writer). Uses SubagentStop per Task 22 fallback path (PostToolUse+Agent unsupported in Claude Code). Fail-open: any error -> exit 0 with stderr warning.",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/dispatch-record-hook.mjs"
          },
          {
            "_source": "metaclaude",
            "_id": "convergence-pass-recorder",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/convergence-pass-recorder.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "_source": "metaclaude",
            "_id": "workflow-stop-enforcement",
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/scripts/workflow-stop-enforcement.mjs"
          }
        ]
      }
    ]
  }
}
