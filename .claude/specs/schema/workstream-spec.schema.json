{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkstreamSpec Front Matter",
  "type": "object",
  "required": [
    "id",
    "title",
    "owner",
    "scope",
    "dependencies",
    "contracts",
    "status",
    "implementation_status"
  ],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "owner": { "type": "string" },
    "scope": { "type": "string" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "approved"]
    },
    "implementation_status": {
      "type": "string",
      "enum": ["not_started", "in_progress", "complete"]
    },
    "e2e_skip": {
      "type": "boolean",
      "description": "Opt out of mandatory e2e-test-writer dispatch for this spec",
      "default": false
    },
    "e2e_skip_rationale": {
      "type": "string",
      "enum": ["pure-refactor", "test-infra", "type-only", "docs-only"],
      "description": "Required when e2e_skip is true. Reason for opting out of E2E tests."
    }
  },
  "additionalProperties": false
}
