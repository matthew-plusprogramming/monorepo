{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Session",
  "description": "Session state tracking for Claude Code orchestration, including active work, phase checkpoints, and subagent task tracking",
  "type": "object",
  "required": [
    "version",
    "updated_at",
    "active_work",
    "phase_checkpoint",
    "subagent_tasks",
    "history"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version of the session schema format"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last session update"
    },
    "active_work": {
      "type": ["object", "null"],
      "description": "Currently active work context. Null when no work is in progress.",
      "properties": {
        "spec_group_id": {
          "type": "string",
          "pattern": "^sg-[a-z0-9-]+$",
          "description": "Reference to the spec group being worked on (sg-<slug>)"
        },
        "workflow": {
          "type": "string",
          "enum": [
            "oneoff-vibe",
            "oneoff-spec",
            "orchestrator",
            "refactor",
            "journal-only"
          ],
          "description": "The workflow type determined by /route"
        },
        "current_phase": {
          "type": "string",
          "enum": [
            "prd_gathering",
            "spec_authoring",
            "atomizing",
            "enforcing",
            "investigating",
            "awaiting_approval",
            "auto_approval",
            "implementing",
            "testing",
            "verifying",
            "reviewing",
            "journaling",
            "complete",
            "challenging",
            "completion_verifying",
            "documenting"
          ],
          "description": "Current phase in the workflow lifecycle"
        },
        "objective": {
          "type": "string",
          "description": "Human-readable description of the work objective"
        }
      },
      "required": ["spec_group_id", "workflow", "current_phase", "objective"]
    },
    "phase_checkpoint": {
      "type": ["object", "null"],
      "description": "Detailed checkpoint state for the current phase. Null when no work is active.",
      "properties": {
        "phase": {
          "type": "string",
          "enum": [
            "prd_gathering",
            "spec_authoring",
            "atomizing",
            "enforcing",
            "investigating",
            "awaiting_approval",
            "auto_approval",
            "implementing",
            "testing",
            "verifying",
            "reviewing",
            "journaling",
            "complete",
            "challenging",
            "completion_verifying",
            "documenting"
          ],
          "description": "Phase this checkpoint represents (should match active_work.current_phase)"
        },
        "phase_skip_warnings": {
          "type": "object",
          "description": "Phase name to skip count mapping for graduated enforcement",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          },
          "default": {}
        },
        "enforcement_counter": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Monotonic counter incremented on every enforcement state mutation via official operations"
        },
        "enforcement_level": {
          "type": "string",
          "enum": ["off", "warn-only", "graduated"],
          "default": "graduated",
          "description": "Enforcement level: off (skip all), warn-only (always warn, never block), graduated (warn first, block on repeat)"
        },
        "override_count": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Number of overrides used this session (shared cap with reset-enforcement, max 3)"
        },
        "atomic_specs_completed": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^as-[0-9]{3}(-[a-z0-9-]+)?$",
            "description": "Atomic spec ID (as-NNN or as-NNN-slug)"
          },
          "description": "List of atomic spec IDs that have been completed"
        },
        "atomic_specs_pending": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^as-[0-9]{3}(-[a-z0-9-]+)?$",
            "description": "Atomic spec ID (as-NNN or as-NNN-slug)"
          },
          "description": "List of atomic spec IDs still pending implementation"
        },
        "next_actions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Ordered list of next concrete actions to take"
        },
        "journal_required": {
          "type": "boolean",
          "description": "Whether a journal entry is required before commit"
        },
        "journal_created": {
          "type": "boolean",
          "description": "Whether the required journal entry has been created"
        },
        "journal_entry_path": {
          "type": ["string", "null"],
          "description": "Path to the created journal entry"
        }
      },
      "required": ["phase"]
    },
    "subagent_tasks": {
      "type": "object",
      "description": "Tracking of subagent task dispatches and completions",
      "properties": {
        "in_flight": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/subagent_task"
          },
          "description": "Currently executing subagent tasks"
        },
        "completed_this_session": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/subagent_task"
          },
          "description": "Subagent tasks completed in this session"
        }
      },
      "required": ["in_flight", "completed_this_session"]
    },
    "convergence": {
      "type": "object",
      "description": "Per-gate convergence state tracking with clean pass counts",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "clean_pass_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of consecutive clean passes recorded for this gate"
          }
        },
        "required": ["clean_pass_count"]
      }
    },
    "convergence_evidence": {
      "type": "object",
      "description": "Per-gate evidence arrays recording each convergence pass with structured metadata",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "passes": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/pass_evidence_record"
            },
            "description": "Ordered array of pass evidence records for this gate"
          }
        },
        "required": ["passes"]
      }
    },
    "history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/history_entry"
      },
      "description": "Historical log of session state changes and significant events"
    },
    "deployment": {
      "type": "object",
      "description": "Deployment state tracking. Absent field treated as no deployment detected.",
      "properties": {
        "detected": {
          "type": "boolean",
          "default": false,
          "description": "Whether deployment activity was detected in this session"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of deployment detection"
        },
        "target": {
          "type": "string",
          "maxLength": 256,
          "pattern": "^[a-zA-Z0-9.\\-/:]+$",
          "description": "Deployment target identifier (alphanumeric plus . - / : only, max 256 chars)"
        },
        "method": {
          "type": "string",
          "enum": ["pipeline", "manual"],
          "description": "How deployment was triggered"
        },
        "verified": {
          "type": "boolean",
          "default": false,
          "description": "Whether post-deploy verification completed (legacy compat)"
        },
        "verify_build_passed": {
          "type": "boolean",
          "default": false,
          "description": "Whether verify:build passed"
        },
        "verify_deploy_passed": {
          "type": "boolean",
          "default": false,
          "description": "Whether post-deploy smoke test passed"
        },
        "failed": {
          "type": "boolean",
          "default": false,
          "description": "Whether the deployment itself failed. When true, clears all verification requirements."
        }
      },
      "required": ["detected"]
    }
  },
  "$defs": {
    "subagent_task": {
      "type": "object",
      "description": "A subagent task dispatch record",
      "properties": {
        "task_id": {
          "type": "string",
          "description": "Unique identifier for this task dispatch"
        },
        "subagent_type": {
          "type": "string",
          "enum": [
            "explore",
            "spec-author",
            "atomizer",
            "atomicity-enforcer",
            "interface-investigator",
            "implementer",
            "test-writer",
            "e2e-test-writer",
            "unifier",
            "code-reviewer",
            "security-reviewer",
            "documenter",
            "refactorer",
            "facilitator",
            "browser-tester",
            "prd-writer",
            "prd-critic",
            "prd-reader",
            "prd-amender",
            "challenger",
            "completion-verifier",
            "doc-auditor",
            "flow-verifier"
          ],
          "description": "Type of subagent dispatched"
        },
        "stage": {
          "type": "string",
          "enum": [
            "pre-implementation",
            "pre-test",
            "pre-review",
            "pre-orchestration",
            "prd-review",
            "spec-review",
            "impl-verify",
            "post-impl"
          ],
          "description": "Stage identifier for challenger and flow-verifier subagent dispatches"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the task"
        },
        "dispatched_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when task was dispatched"
        },
        "completed_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "ISO 8601 timestamp when task completed. Null if in flight."
        },
        "status": {
          "type": "string",
          "enum": ["in_flight", "completed", "failed", "cancelled"],
          "description": "Current status of the task"
        },
        "result_summary": {
          "type": ["string", "null"],
          "description": "Brief summary of task result. Null if not yet completed."
        },
        "spec_group_id": {
          "type": ["string", "null"],
          "pattern": "^sg-[a-z0-9-]+$",
          "description": "Associated spec group if applicable"
        },
        "atomic_spec_id": {
          "type": ["string", "null"],
          "pattern": "^as-[0-9]{3}(-[a-z0-9-]+)?$",
          "description": "Associated atomic spec if applicable"
        }
      },
      "required": [
        "task_id",
        "subagent_type",
        "description",
        "dispatched_at",
        "status"
      ]
    },
    "pass_evidence_record": {
      "type": "object",
      "description": "A structured record of a single convergence pass with verifiable metadata",
      "properties": {
        "pass_number": {
          "type": "integer",
          "minimum": 1,
          "description": "Auto-incremented pass number (1-indexed)"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the pass was recorded"
        },
        "agent_type": {
          "type": "string",
          "description": "The convergence agent type that performed this pass"
        },
        "findings_count": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Number of findings reported by the agent (null if extraction failed)"
        },
        "findings_hash": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 hex hash of sorted finding IDs (null if extraction failed)"
        },
        "clean": {
          "type": "boolean",
          "description": "Whether this pass was clean (no findings)"
        },
        "record_source": {
          "type": "string",
          "enum": ["hook", "manual", "manual_fallback"],
          "description": "How this record was created: hook (automated), manual (agent CLI), manual_fallback (hook extraction failure)"
        },
        "auto_decision_batch_id": {
          "type": ["string", "null"],
          "description": "Optional link to the auto-decision engine batch that processed findings"
        },
        "auto_decision_complete": {
          "type": ["boolean", "null"],
          "description": "Whether the auto-decision batch completed successfully (null if no batch)"
        }
      },
      "required": [
        "pass_number",
        "timestamp",
        "agent_type",
        "findings_count",
        "findings_hash",
        "clean",
        "record_source"
      ]
    },
    "history_entry": {
      "type": "object",
      "description": "A historical record of a session event",
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of the event"
        },
        "event_type": {
          "type": "string",
          "enum": [
            "session_start",
            "session_resume",
            "work_started",
            "phase_transition",
            "subagent_dispatched",
            "subagent_completed",
            "checkpoint_saved",
            "work_completed",
            "work_abandoned",
            "error_occurred",
            "override_skip",
            "reset_enforcement",
            "enforcement_level_change",
            "completion_checklist",
            "convergence_update",
            "convergence_pass_recorded"
          ],
          "description": "Type of event that occurred"
        },
        "details": {
          "type": "object",
          "description": "Event-specific details",
          "properties": {
            "from_phase": {
              "type": "string",
              "description": "Previous phase (for phase_transition events)"
            },
            "to_phase": {
              "type": "string",
              "description": "New phase (for phase_transition events)"
            },
            "spec_group_id": {
              "type": "string",
              "description": "Associated spec group ID"
            },
            "task_id": {
              "type": "string",
              "description": "Associated task ID (for subagent events)"
            },
            "subagent_type": {
              "type": "string",
              "description": "Subagent type (for subagent events)"
            },
            "error_message": {
              "type": "string",
              "description": "Error message (for error_occurred events)"
            },
            "message": {
              "type": "string",
              "description": "Human-readable description of the event"
            }
          }
        }
      },
      "required": ["timestamp", "event_type"]
    }
  }
}
