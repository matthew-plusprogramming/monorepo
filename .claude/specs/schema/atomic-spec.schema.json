{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AtomicSpec",
  "description": "An independently testable, deployable, and reversible unit of work",
  "type": "object",
  "required": [
    "id",
    "title",
    "requirements_refs",
    "description",
    "acceptance_criteria",
    "atomicity_justification"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^as-[0-9]{3}[a-z]?-[a-z0-9-]+$",
      "description": "Unique identifier (as-001-<slug>)"
    },
    "title": {
      "type": "string",
      "description": "Short descriptive title"
    },
    "date": { "type": "string" },
    "spec_group": { "type": "string" },
    "parent_spec": { "type": "string" },
    "estimated_effort": { "type": "string" },
    "requirements_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^REQ(-[A-Z]+)?-[0-9]+[a-z]?$"
      },
      "minItems": 1,
      "description": "Which requirements this atomic spec fulfills"
    },
    "parent_spec_section": {
      "type": "string",
      "description": "Reference to section in spec.md this was decomposed from"
    },
    "description": {
      "type": "string",
      "description": "Single testable behavior this spec covers"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^AC[0-9]+\\.[0-9]+$" },
          "criterion": { "type": "string" },
          "testable": { "type": "boolean", "default": true }
        },
        "required": ["id", "criterion"]
      },
      "minItems": 1
    },
    "test_strategy": {
      "type": "string",
      "description": "How this will be tested in isolation"
    },
    "deployment_notes": {
      "type": "string",
      "description": "Any deployment considerations for this unit"
    },
    "rollback_strategy": {
      "type": "string",
      "description": "How to reverse this change safely"
    },
    "atomicity_justification": {
      "type": "object",
      "description": "Why this is at the right level of atomicity",
      "properties": {
        "independently_testable": { "type": "string" },
        "independently_deployable": { "type": "string" },
        "independently_reviewable": { "type": "string" },
        "independently_reversible": { "type": "string" }
      },
      "required": [
        "independently_testable",
        "independently_deployable",
        "independently_reviewable",
        "independently_reversible"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "implementing",
        "implemented",
        "tested",
        "verified",
        "superseded"
      ],
      "default": "pending"
    },
    "implementation_evidence": {
      "type": "array",
      "description": "Links to code implementing this spec",
      "items": {
        "type": "object",
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "description": { "type": "string" }
        }
      }
    },
    "test_evidence": {
      "type": "array",
      "description": "Links to tests verifying this spec",
      "items": {
        "type": "object",
        "properties": {
          "file": { "type": "string" },
          "test_name": { "type": "string" },
          "ac_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "e2e_skip": {
      "type": "boolean",
      "description": "Opt out of mandatory e2e-test-writer dispatch for this spec",
      "default": false
    },
    "e2e_skip_rationale": {
      "type": "string",
      "enum": [
        "pure-refactor",
        "test-infra",
        "type-only",
        "docs-only",
        "pure-compute"
      ],
      "description": "Required when e2e_skip is true. Reason for opting out of E2E tests."
    },
    "runtime_validation_required": {
      "type": "boolean",
      "default": false,
      "description": "When true, terminal completion requires /manual-test with a structured passing result."
    },
    "runtime_validation_surface": {
      "type": "string",
      "enum": [
        "plugin",
        "mcp",
        "connector",
        "browser-extension",
        "dynamic-tool-body",
        "plugin-loader",
        "other"
      ],
      "description": "Runtime-loaded surface that requires live manual validation."
    },
    "runtime_validation_rationale": {
      "type": "string",
      "description": "Required when runtime_validation_required is true. Explains why static/generated gates are insufficient."
    },
    "runtime_env": {
      "type": "object",
      "description": "Runtime environment tier declaration (contract-runtime-env-frontmatter v1.0).",
      "required": ["liveness"],
      "properties": {
        "liveness": {
          "type": "string",
          "enum": ["L1", "L2", "L3"],
          "description": "Runtime tier required by this spec under test."
        },
        "rationale": {
          "type": "string",
          "description": "Free-form rationale; required (non-empty) when liveness is L2 or L3."
        },
        "prefer_ipv6": {
          "type": "boolean",
          "default": false,
          "description": "If true, address discovery prefers IPv6."
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "liveness": { "enum": ["L2", "L3"] } },
            "required": ["liveness"]
          },
          "then": {
            "required": ["rationale"],
            "properties": {
              "rationale": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    },
    "crosses_boundary": {
      "type": "boolean",
      "description": "Author-declared scope gate. true (default) = in-scope for runtime connectivity."
    },
    "crosses_boundary_rationale": {
      "type": "string",
      "description": "Required when crosses_boundary is false; explains why the spec is out of scope."
    },
    "runtime_connectivity_budget_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 60000,
      "description": "Per-spec override for the Gate 5 execution budget. Hard cap 60000ms."
    },
    "runtime_connectivity_budget_rationale": {
      "type": "string",
      "description": "Required when runtime_connectivity_budget_ms is set; explains why the override is needed."
    },
    "security_surface": {
      "description": "Authoritative enum (NOT boolean). One of: single enum value, array of enum values, or null.",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "auth",
            "cors",
            "session",
            "csrf",
            "serialization",
            "input-validation"
          ]
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "auth",
              "cors",
              "session",
              "csrf",
              "serialization",
              "input-validation"
            ]
          }
        },
        { "type": "null" }
      ]
    },
    "pure_compute_entry_points": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Entry point file paths for the pure-compute static-analysis sub-check. Required (non-empty) when e2e_skip_rationale is pure-compute."
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "runtime_validation_required": { "const": true } },
        "required": ["runtime_validation_required"]
      },
      "then": {
        "required": [
          "runtime_validation_surface",
          "runtime_validation_rationale"
        ],
        "properties": {
          "runtime_validation_rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": { "crosses_boundary": { "const": false } },
        "required": ["crosses_boundary"]
      },
      "then": {
        "required": ["crosses_boundary_rationale"],
        "properties": {
          "crosses_boundary_rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "if": { "required": ["runtime_connectivity_budget_ms"] },
      "then": {
        "required": ["runtime_connectivity_budget_rationale"],
        "properties": {
          "runtime_connectivity_budget_rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "e2e_skip": { "const": true },
          "e2e_skip_rationale": { "const": "pure-compute" }
        },
        "required": ["e2e_skip", "e2e_skip_rationale"]
      },
      "then": {
        "required": ["pure_compute_entry_points"],
        "properties": {
          "pure_compute_entry_points": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  ]
}
